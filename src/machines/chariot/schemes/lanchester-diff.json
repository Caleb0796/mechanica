{
  "id": "lanchester-diff",
  "scholar": {
    "zh": "乔治·兰彻斯特",
    "en": "George Lanchester"
  },
  "year": 1932,
  "summary": {
    "zh": "以连续差动机构求两侧车轮反向输入的平均值，替代燕肃式侧落离合传动。",
    "en": "Replaces the side-selecting clutch train with a continuous differential averaging oppositely signed road-wheel inputs."
  },
