  "removePartIds": ["left-clutch-dog", "right-clutch-dog", "clutch-yoke"],
  "addConstraints": [
    {
      "type": "lockstep",
      "a": "left-road-wheel",
      "b": "differential-sun-left",
      "ratio": 2,
      "provenance": {
        "kind": "tuice",
        "ref": "lanchester-diff",
        "note": "Signed input scaling yields chassis yaw from the left-right wheel difference."
      }
    },
    {
      "type": "lockstep",
      "a": "right-road-wheel",
      "b": "differential-sun-right",
      "ratio": -2,
      "provenance": {
        "kind": "tuice",
        "ref": "lanchester-diff",
        "note": "The opposite sign converts the differential average into wheel-angle subtraction."
      }
    },
    {
      "type": "differential",
      "carrier": "chassis-pivot",
      "sunA": "differential-sun-left",
      "sunB": "differential-sun-right",
      "ratio": 1,
      "provenance": {
        "kind": "tuice",
        "ref": "lanchester-diff",
        "note": "Continuous differential alternative; no direct textual basis."
      }
    },
    {
      "type": "lockstep",
      "a": "chassis-pivot",
      "b": "differential-carrier",
      "ratio": 1,
      "provenance": {
        "kind": "tuice",
        "ref": "lanchester-diff",
        "note": "The visible carrier follows the computed differential output."
      }
    }
  ],
  "collisionWhitelist": [
